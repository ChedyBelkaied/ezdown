# ════════════════════════════════════════════════════════
#  EZDown Environment Variables
#  Copy this file to .env and fill in your real values
# ════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
SITE_URL=http://localhost:3000

# !! Change this to a long random string in production !!
SECRET_KEY=change-this-to-a-long-random-secret-key-min-32-chars

# ── Stripe ──────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Webhook secret — from Stripe dashboard > Webhooks
# Local testing: use `stripe listen --forward-to localhost:3000/billing/webhook`
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# Price IDs — create in Stripe dashboard > Products
# Product: "EZDown Pro Monthly" → Price: $4.99/month recurring
STRIPE_PRICE_PRO_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX
# Product: "EZDown Pro Yearly"  → Price: $39.99/year recurring
STRIPE_PRICE_PRO_YEARLY=price_XXXXXXXXXXXXXXXXXXXXXXXX
